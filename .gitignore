# Dependency directories
node_modules/
**/node_modules/

# Production build outputs
dist/
**/dist/
build/
**/build/

# Local env files (secrets/credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (next.js / node)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data / User Uploads
# Keeps the uploads directory but ignores all files uploaded inside it
backend/uploads/*
!backend/uploads/.gitkeep

# Editor-specific files/directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/

# OS-specific files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini
